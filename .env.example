# ── Telegram Bot ──────────────────────────────────────────────
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow prompts
# 3. Copy the token you receive
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# 4. Message YOUR BOT once (so it knows your chat ID)
# 5. Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 6. Find the "id" inside "chat" object → that's your CHAT_ID
TELEGRAM_CHAT_ID=6885922938

# ── App Settings ───────────────────────────────────────────────
# Set to "true" for demo (days → minutes), "false" for real intervals
DEMO_MODE=true

# ── n8n ────────────────────────────────────────────────────────
# If running locally without ngrok, leave as-is
# If using ngrok for Telegram webhook: set to your ngrok https URL
WEBHOOK_URL=http://localhost:5678

# ── Gemini API (for Chatbot tab in Streamlit) ──────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: force a specific model (leave empty for auto-detect)
# Examples: gemini-2.5-flash, gemini-2.0-flash
GEMINI_MODEL=

# ── Backend (set automatically by docker-compose) ──────────────
# BACKEND_URL=http://backend:8000   ← used inside Docker network
# BACKEND_URL=http://localhost:8000 ← used from your browser/curl
